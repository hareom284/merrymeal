# === Required for prod ===
# Django secret — generate fresh, never reuse dev/staging.
DJANGO_SECRET_KEY=replace-with-50-char-secret
# Prod settings module.
DJANGO_SETTINGS_MODULE=config.settings.prod
# Must stay False in prod.
DJANGO_DEBUG=False
# Comma-separated host list.
DJANGO_ALLOWED_HOSTS=YOUR_DOMAIN

# Managed MySQL recommended — point HOST to the managed endpoint.
MYSQL_HOST=YOUR_MYSQL_HOST
MYSQL_PORT=3306
MYSQL_DATABASE=merrymeal
MYSQL_USER=YOUR_MYSQL_USER
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD
# Only used by the in-compose mysql:8 service on its first init.
MYSQL_ROOT_PASSWORD=REPLACE_IF_USING_LOCAL_MYSQL

# Managed Redis recommended.
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_REDIS_HOST:6379/0

# Email transport — example: AWS SES.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=email-smtp.ap-southeast-2.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=YOUR_SES_USER
EMAIL_HOST_PASSWORD=YOUR_SES_PASSWORD
DEFAULT_FROM_EMAIL=noreply@YOUR_DOMAIN

# Australia/Melbourne — confirmed by docs/superpowers/specs §5.
TIME_ZONE=Australia/Melbourne
