# /etc/nginx/sites-available/merrymeal — sample, NOT auto-loaded.
# Copy to /etc/nginx/sites-enabled/. Domain (merrymeal.freebarcodeqr.com) is
# already inlined; if you deploy to a different host, sed it through:
#   sudo sed -i 's/merrymeal.freebarcodeqr.com/your.domain.tld/g' /etc/nginx/sites-available/merrymeal
# Then `nginx -t && systemctl reload nginx`.

upstream merrymeal_web {
    server 127.0.0.1:8000 fail_timeout=0;
}

# HTTP → HTTPS redirect.
server {
    listen 80;
    server_name merrymeal.freebarcodeqr.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name merrymeal.freebarcodeqr.com;

    ssl_certificate     /etc/letsencrypt/live/merrymeal.freebarcodeqr.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/merrymeal.freebarcodeqr.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # Tightening — match Django's HSTS settings in compose.prod.yaml.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    client_max_body_size 25M;          # proof-of-delivery photos in Epic 04
    keepalive_timeout 65;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript image/svg+xml;
    gzip_min_length 1024;

    # Static files served straight from disk.
    location /static/ {
        alias /srv/merrymeal/static/dist/;
        expires 1y;
        access_log off;
        add_header Cache-Control "public, immutable";
    }

    location /media/ {
        # Phase 0 only — Epic 04 moves media to S3 via django-storages.
        alias /srv/merrymeal/media/;
        expires 30d;
    }

    location / {
        proxy_pass http://merrymeal_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }
}
