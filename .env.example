# Django settings module — `dev` locally, `prod` in production, `test` in CI.
DJANGO_SETTINGS_MODULE=config.settings.dev

# Django secret key — generate fresh per environment, never reuse prod's.
DJANGO_SECRET_KEY=change-me-in-prod

# DEBUG mode — must be False in production.
DJANGO_DEBUG=True

# Comma-separated host list Django will serve.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL host — `mysql` inside the compose stack, `localhost` for native dev.
MYSQL_HOST=localhost
# MySQL port — usually 3306.
MYSQL_PORT=3306
# MySQL database name.
MYSQL_DATABASE=merrymeal
# MySQL application user.
MYSQL_USER=merrymeal
# MySQL application user password.
MYSQL_PASSWORD=merrymeal
# MySQL root password — used by the compose stack on first init.
MYSQL_ROOT_PASSWORD=rootpass

# Redis URL — used by Django-Q2 worker + cache.
REDIS_URL=redis://localhost:6379/0

# === Production-only security knobs (no-ops in dev/test) ===
# Force every request to HTTPS — must be True in prod, leave False locally.
DJANGO_SECURE_SSL_REDIRECT=False
# Marks the session cookie Secure (HTTPS-only).
DJANGO_SESSION_COOKIE_SECURE=False
# Marks the CSRF cookie Secure (HTTPS-only).
DJANGO_CSRF_COOKIE_SECURE=False
# HSTS max-age in seconds — 31536000 = 1 year (production target).
DJANGO_SECURE_HSTS_SECONDS=0
# HSTS includeSubDomains directive.
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# HSTS preload directive — only enable once domain is on hstspreload.org.
DJANGO_SECURE_HSTS_PRELOAD=False

# === Reserved for later sprints — leave commented until wired in ===
# Stripe (Epic 05 — donations)
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Twilio (Epic 04 — delivery SMS)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
# AWS S3 (Epic 04 — proof-of-delivery media)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
