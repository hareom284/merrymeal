# ---------------------------------------------------------------
# Django
# ---------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Site URL used in email links, Stripe redirects, password-reset URLs.
SITE_URL=http://localhost:8000

# ---------------------------------------------------------------
# Database — choose ONE: either DATABASE_URL, or the MYSQL_* set.
# ---------------------------------------------------------------
DATABASE_URL=mysql://merrymeal:merrymeal@127.0.0.1:3306/merrymeal

# MYSQL_* are read directly by config/settings/base.py when the
# MySQL driver is in use (Docker Compose dev + prod). Defaults
# match the bundled docker-compose.yml service.
MYSQL_DATABASE=merrymeal
MYSQL_USER=merrymeal
MYSQL_PASSWORD=merrymeal
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Redis (Phase 0 doesn't require it; needed for background jobs in later phases)
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------
# Seed admin (one-shot superuser created by `manage.py seed_admin`).
# Used by CI smoke and dev bootstrap; SAFE to leave the defaults in
# dev — change them in any shared environment.
# ---------------------------------------------------------------
DJANGO_ADMIN_EMAIL=admin@merrymeal.local
DJANGO_ADMIN_NAME=Site Admin
DJANGO_ADMIN_PASSWORD=changeme

# ---------------------------------------------------------------
# Security / HTTPS hardening (read by config/settings/prod.py).
# Leave at the secure defaults; dev.py never reads these so flipping
# them off in dev is unnecessary.
# ---------------------------------------------------------------
# 30 days in seconds. Tell browsers to upgrade every future request.
DJANGO_SECURE_HSTS_SECONDS=2592000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

# ---------------------------------------------------------------
# Email (SMTP). dev.py defaults to the console backend when these
# are blank/localhost — real mail in dev needs SMTP creds below.
# ---------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
# Per-connection timeout in seconds (smtplib default is no timeout).
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=no-reply@merrymeal.local
# Address Django stamps on error / 500 emails. Defaults to DEFAULT_FROM_EMAIL.
SERVER_EMAIL=no-reply@merrymeal.local

# Address that receives the failure alert when a member has no linked
# caregiver (Story 4.13 fallback).
OFFICE_ALERT_EMAIL=office@merrymeal.org
# Phone rendered in failure alert templates ("Call the office on ...").
OFFICE_PHONE=03 9000 0000

# ---------------------------------------------------------------
# Media / S3. Local disk in dev; S3 in prod via django-storages.
# Story 4.9 — POD photos. Story 5.5 — receipt PDFs.
# ---------------------------------------------------------------
MEDIA_URL=/media/
MEDIA_ROOT=./media
AWS_S3_BUCKET=
AWS_S3_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------
# SMS — Story 4.13. `console` writes to apps.core.testing.sms_outbox
# and stdout for tests/dev; `twilio` is wired in prod only and
# requires the three TWILIO_* keys below.
# ---------------------------------------------------------------
SMS_BACKEND=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---------------------------------------------------------------
# Stripe (Story 5.4 — donate checkout + webhook).
# Publishable key may safely ship to the browser; secret + webhook
# secret are server-only. Defaults are deliberate placeholders so a
# missing .env in prod fails the first Stripe call loudly instead of
# silently charging the wrong account.
# ---------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_test_only

# ---------------------------------------------------------------
# Donations — receipt branding + impact knob. See Story 5.5 + 5.6.
# Defaults are PLACEHOLDERS — replace with the real charity ABN /
# address before the first live charge or donors get bogus tax data.
# ---------------------------------------------------------------
# Per-portion cooked-meal cost in cents — the impact line on the donate
# page renders "your $X = N meals" via this knob. 300c = $3.
MEAL_COST_CENTS=300
DONATIONS_FROM_EMAIL=receipts@merrymeal.org.au
DONATIONS_CHARITY_ABN=12 345 678 901
DONATIONS_CHARITY_ADDRESS=PO Box 1, Melbourne VIC 3000
# FY tax receipt (Story 6.4). Default to the DONATIONS_CHARITY_* values
# so the email receipt and the printed FY receipt stay in lockstep.
MERRYMEAL_ABN=12 345 678 901
MERRYMEAL_ADDRESS=PO Box 1, Melbourne VIC 3000

# ---------------------------------------------------------------
# Mapbox Static Images API (Story 12.7 — member /track/ page).
# Leave blank in dev/test — static_map_url returns None and the
# template falls back to a stylised placeholder. No broken images.
# ---------------------------------------------------------------
MAPBOX_TOKEN=

# ---------------------------------------------------------------
# AI assistant (Anthropic Claude). Member + admin chat widget. Leave
# blank to disable the widget gracefully — the service raises
# ClaudeUnavailable and the view falls back to a "please call the
# office" reply instead of crashing the page.
# Generate a key at https://console.anthropic.com/settings/keys
# (starts `sk-ant-`).
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=
# Claude Haiku 4.5 is the cheapest/fastest current-generation model
# and is plenty for short factual Q&A. Bump to `claude-sonnet-4-6`
# if member replies feel sloppy; `claude-opus-4-7` is overkill.
ANTHROPIC_MODEL=claude-haiku-4-5
# Rate limit — protects the charity's Claude spend from a runaway
# chat client. Per-user cap stops one chatty member from draining
# the global cap; the global cap keeps spend predictable on the
# default tier. Window is in seconds.
ANTHROPIC_RATE_LIMIT_PER_USER=10
ANTHROPIC_RATE_LIMIT_GLOBAL=12
ANTHROPIC_RATE_LIMIT_WINDOW_SECONDS=60
