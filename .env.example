# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=mysql://merrymeal:merrymeal@127.0.0.1:3306/merrymeal

# Redis (Phase 0 doesn't require it; needed for background jobs in later phases)
REDIS_URL=redis://localhost:6379/0

# Gmail SMTP. To send real mail in dev, also set:
# Otherwise dev.py defaults to the console backend (terminal output only).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@merrymeal.local



GEMINI_API_KEY=
# Model name — Flash is the cheapest/fastest free-tier model. Bump to
# ``gemini-2.0-pro`` (or whatever the current Pro generation is) once
# the charity has paid quota.

GEMINI_MODEL=gemini-flash-latest
# Rate limit (Gemini free tier is 15 req/min). The per-user cap stops
# one chatty member from draining the global quota; the global cap
# stays a few requests under the upstream ceiling so a coincidental
# burst doesn't trigger an upstream 429. Window is in seconds.
GEMINI_RATE_LIMIT_PER_USER=10
GEMINI_RATE_LIMIT_GLOBAL=12
GEMINI_RATE_LIMIT_WINDOW_SECONDS=60

