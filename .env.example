# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL (compose stack uses MYSQL_HOST=mysql; native/macOS uses localhost)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=merrymeal
MYSQL_USER=merrymeal
MYSQL_PASSWORD=merrymeal
MYSQL_ROOT_PASSWORD=rootpass

# Redis (used by Django-Q2 worker + cache)
REDIS_URL=redis://localhost:6379/0
