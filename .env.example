# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Public base URL used in outbound emails (welcome / set-password / rejection).
# Dev: http://localhost:8000  ·  Prod: https://merrymeal.freebarcodeqr.com
SITE_URL=http://localhost:8000

# Database — DATABASE_URL is the primary connection string.
DATABASE_URL=mysql://merrymeal:merrymeal@127.0.0.1:3306/merrymeal

# MySQL connection components (used by config/settings/base.py DATABASES).
# Database name
MYSQL_DATABASE=merrymeal
# Database user
MYSQL_USER=merrymeal
# Database password
MYSQL_PASSWORD=merrymeal
# Database host (overridden to "mysql" inside docker compose)
MYSQL_HOST=localhost
# Database port
MYSQL_PORT=3306

# Redis (Phase 0 doesn't require it; needed for background jobs in later phases)
REDIS_URL=redis://localhost:6379/0

# Email — dev.py defaults EMAIL_BACKEND to the console backend (prints to
# the runserver terminal). Set EMAIL_BACKEND below to force real SMTP.
# Port 465 → EMAIL_USE_SSL=True,  EMAIL_USE_TLS=False
# Port 587 → EMAIL_USE_SSL=False, EMAIL_USE_TLS=True
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# SMTP host (e.g. smtp.gmail.com, smtp.sendgrid.net, localhost for Mailpit)
EMAIL_HOST=localhost
# SMTP port (25 / 465 / 587 / 1025-for-Mailpit)
EMAIL_PORT=25
# SMTP username (Gmail: full email address)
EMAIL_HOST_USER=
# SMTP password (Gmail: 16-char App Password, NOT account password)
EMAIL_HOST_PASSWORD=
# STARTTLS — use with port 587
EMAIL_USE_TLS=False
# Implicit SSL — use with port 465
EMAIL_USE_SSL=False
# Socket timeout (seconds) for SMTP connect/send
EMAIL_TIMEOUT=10
# From address on every outbound message
DEFAULT_FROM_EMAIL=no-reply@merrymeal.local
# From address Django uses for internal error mail to ADMINS
SERVER_EMAIL=no-reply@merrymeal.local

# Platform super-admin seeded by `python manage.py seed_admin` on every boot.
# Login email for the auto-created super-admin
DJANGO_ADMIN_EMAIL=admin@merrymeal.freebarcodeqr.com
# Display name on the admin user row
DJANGO_ADMIN_NAME=Site Admin
# Admin password — if empty, seed_admin generates a random one on first run
# and prints it once. Change this value to rotate on next boot.
DJANGO_ADMIN_PASSWORD=

# Production security hardening (read by config/settings/prod.py).
# HSTS max-age in seconds (default 30 days)
DJANGO_SECURE_HSTS_SECONDS=2592000
# Apply HSTS to all subdomains
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# Allow site to be submitted to the HSTS preload list
DJANGO_SECURE_HSTS_PRELOAD=True
# Redirect all HTTP requests to HTTPS
DJANGO_SECURE_SSL_REDIRECT=True
# Send session cookie only over HTTPS
DJANGO_SESSION_COOKIE_SECURE=True
# Send CSRF cookie only over HTTPS
DJANGO_CSRF_COOKIE_SECURE=True

# Media (Story 4.9 — POD photo storage).
# Public URL prefix served by the storage backend ("/media/" in dev,
# CDN domain in prod via django-storages).
MEDIA_URL=/media/
# Filesystem path for media in dev (FileSystemStorage). Ignored in prod
# when DEFAULT_FILE_STORAGE is S3.
MEDIA_ROOT=

# S3 (prod only — django-storages backend in config/settings/prod.py).
# Leave blank in dev so default_storage stays on FileSystemStorage.
# Bucket name, e.g. merrymeal-pod-prod
AWS_S3_BUCKET=
# AWS region for the bucket
AWS_S3_REGION=ap-southeast-2
# IAM access key id with PutObject on the POD bucket
AWS_ACCESS_KEY_ID=
# Matching secret access key
AWS_SECRET_ACCESS_KEY=

# SMS (Story 4.13 — caregiver alerts on failed delivery).
# Which backend `apps.core.services.sms.send_sms` uses. ``console`` (dev
# / CI) appends to an in-memory outbox; ``twilio`` (prod, see
# config/settings/prod.py) makes a real REST call.
SMS_BACKEND=console
# Fallback email address used when the failed delivery's member has no
# linked caregiver. The office reads this inbox.
OFFICE_ALERT_EMAIL=office@merrymeal.org
# Phone number rendered in the alert email + SMS ("Call the office on …").
OFFICE_PHONE=03 9000 0000

# Twilio (prod only — used by config/settings/prod.py via SMS_BACKEND=twilio).
# Account SID from the Twilio console
TWILIO_ACCOUNT_SID=
# Auth token paired with the SID
TWILIO_AUTH_TOKEN=
# Sender phone number / Messaging Service SID Twilio sends from
TWILIO_FROM=

# Stripe (Story 5.4 — Checkout session + signature-verified webhook).
# Replace these placeholders in your local .env. Never commit real keys —
# a real ``sk_live_…`` value in source control triggers an instant key
# rotation per the Story 5.4 reviewer checklist.
# Publishable key (pk_test_… / pk_live_…) sent to the browser. Safe to
# expose; only authorises Checkout session redirects.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# Secret key (sk_test_… / sk_live_…) used server-side to create Checkout
# sessions in apps.donations.services.stripe_checkout.
STRIPE_SECRET_KEY=sk_test_replace_me
# Webhook signing secret (whsec_…). The donations webhook view passes
# this to ``stripe.Webhook.construct_event`` so forged callbacks return
# HTTP 401 with zero DB writes.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Donor-impact conversion (Story 5.6 — "your $50 = 16 meals" caption).
# Cost of one cooked-meal portion, in integer cents. Read by
# apps.donations.services.impact.meals_for_amount and the matching
# template filter. Default $3 per meal — bump per Sprint 09 brief.
MEAL_COST_CENTS=300

# Receipt email (Story 5.5 — sent when a Donation flips to completed).
# From address stamped on every receipt. Donors reply to this inbox for
# refunds / queries, so use a monitored address in prod.
DONATIONS_FROM_EMAIL=receipts@merrymeal.org.au
# Charity ABN rendered in the receipt body — required by the ATO for
# the receipt to count as a tax-deductible-gift record. Plain text, no
# validation (storefront concern). Override in prod with the registered
# DGR ABN.
DONATIONS_CHARITY_ABN=12 345 678 901
# Charity registered address printed alongside the ABN. Multi-line
# strings work — env reader keeps them as a single string and the
# template renders them verbatim.
DONATIONS_CHARITY_ADDRESS=PO Box 1, Melbourne VIC 3000

# FY tax receipt (Story 6.4 — printer-friendly per-donor FY receipt
# at /donor/receipts/<fy>/). Defaults to DONATIONS_CHARITY_ABN so
# operators only need to set one variable; override only if the FY
# receipt should carry a different registered name than the email
# receipt does (rare — leave unset in prod unless the accountant
# explicitly asks for a split).
MERRYMEAL_ABN=12 345 678 901
# FY receipt footer address. Same defaulting rule as MERRYMEAL_ABN —
# unset in dev to inherit DONATIONS_CHARITY_ADDRESS, set in prod only
# if you genuinely need divergence between the two receipt surfaces.
MERRYMEAL_ADDRESS=PO Box 1, Melbourne VIC 3000

# Mapbox Static Images API token (Story 12.7). Sign up at
# https://account.mapbox.com — the free tier covers 50k tile requests
# per month, which is well above MerryMeal's expected member load.
# Leave blank in dev/test; the track-delivery page falls back to a
# placeholder map when this is unset rather than rendering a broken image.
MAPBOX_TOKEN=

# Google Gemini API key — fetch from https://aistudio.google.com/apikey
# (free tier: ~15 req/min, 1500 req/day, no credit card required).
# Leave blank in dev/test to disable the AI assistant cleanly; the
# chat widget still renders but POSTs return a static "please call
# the office" reply instead of crashing on a missing key.
GEMINI_API_KEY=
# Model name — Flash is the cheapest/fastest free-tier model. Bump to
# ``gemini-2.0-pro`` (or whatever the current Pro generation is) once
# the charity has paid quota.
GEMINI_MODEL=gemini-2.0-flash
