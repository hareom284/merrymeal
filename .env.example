# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=mysql://merrymeal:merrymeal@127.0.0.1:3306/merrymeal

# Redis (Phase 0 doesn't require it; needed for background jobs in later phases)
REDIS_URL=redis://localhost:6379/0

# Gmail SMTP. To send real mail in dev, also set:
# Otherwise dev.py defaults to the console backend (terminal output only).
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=
EMAIL_USE_SSL=
DEFAULT_FROM_EMAIL=


